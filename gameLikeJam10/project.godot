[application]

config/name="Game-likeJam10"
run/main_scene="uid://8mqlsnp7uqw4"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

Enums="*uid://c67vsaorf4o3k"
EventBus="*uid://duqq0fs87lk6k"

[debug]

